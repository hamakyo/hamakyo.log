# Notion API Configuration
# Notion同期スクリプト用の環境変数設定ファイル

# Notion Integration Token
# Notion開発者ページ (https://www.notion.so/my-integrations) で作成
NOTION_TOKEN=

# Notion Database ID  
# 同期対象のNotionデータベースページのURL末尾のID（32文字）
# 例: https://www.notion.so/{workspace}/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=

# Optional: Memosで同期対象を示すRelationタグ
NOTION_SYNC_TAG=Study.Log

# Optional: ブログ上へ公開しない内部タグ（カンマ区切り）
NOTION_INTERNAL_TAGS=Study.Log,INBOX

# Optional: Notionプロパティ名（現在のAll/Memos/Tags構成に合わせた既定値）
NOTION_TAGS_PROPERTY=Tags
NOTION_PUBLIC_TAG_PROPERTY=ブログ表示
NOTION_TAG_DESCRIPTION_PROPERTY=タグの説明
NOTION_TAG_ARCHIVE_PROPERTY=アーカイブ

# Gemini API Configuration
# Google AI Studioで作成したAPIキー。未設定・API失敗時も同期は継続し、ローカルslugへフォールバックします。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TIMEOUT_MS=15000
GEMINI_MAX_INPUT_CHARS=30000

# 使用方法:
# 1. このファイルを .env.local にコピー
# 2. 上記の値を実際のNotion設定値で置き換え
# 3. pnpm run sync-notion を実行
